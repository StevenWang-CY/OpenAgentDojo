# ─────────────────────────────────────────────────────────────────────
# ROOT .env.example — single source of truth for top-level coordination.
#
# WHAT THIS IS:
#   The canonical reference for every environment variable the platform
#   reads. New variables land here FIRST, then propagate to the more
#   specific examples (apps/api/.env.example, infra/compose/.env.compose.example).
#
# WHEN TO USE IT:
#   • Local "I just cloned the repo" bring-up:  cp .env.example .env
#   • Docs / onboarding reference.
#   • The audit baseline — drift between this file and the others is a bug.
#
# WHEN TO USE THE OTHERS:
#   • apps/api/.env.example      → just running the API (no web, no compose)
#   • infra/compose/.env.compose.example → running the full compose stack
#
# Real secrets live in keys.md (gitignored) or Fly secrets. NEVER commit one.
# ─────────────────────────────────────────────────────────────────────

# --- Backend (apps/api) ---
ARENA_ENV=development
DATABASE_URL=postgresql+asyncpg://arena:arena@localhost:5432/arena
SYNC_DATABASE_URL=postgresql://arena:arena@localhost:5432/arena
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=arena-minio
S3_SECRET_ACCESS_KEY=arena-minio-secret
S3_BUCKET=arena-artifacts
S3_REGION=us-east-1

# Sandbox driver: 'local' (dev only, no isolation) or 'docker' (recommended)
SANDBOX_DRIVER=local
SANDBOX_WORKDIR=/tmp/arena-sandboxes
SANDBOX_MAX_CONCURRENT=10
SANDBOX_TIMEOUT_SECONDS=1800
# ARENA_SECCOMP_PROFILE: path to a docker seccomp JSON profile applied to
# every sandbox container. Falls back to a minimal in-repo profile when unset.
# Production should pin this to a vetted profile in infra/security/seccomp/.
ARENA_SECCOMP_PROFILE=
# ARENA_RUN_LOCAL_SETUP=1 forces the worker to execute mission setup_commands
# even on the local (subprocess) driver. Off by default because the local
# driver is meant for fast, hermetic unit tests where setup costs dominate.
ARENA_RUN_LOCAL_SETUP=

# P0-5 (legal pages + cookie consent) — bump CONSENT_POLICY_VERSION every
# time the cookie/privacy policy text changes so existing consent rows are
# treated as stale and the cookie banner re-prompts. The server stamps this
# value into ``user_consents.version`` on every POST /me/consent.
CONSENT_POLICY_VERSION=1
# IP_HASH_SALT is mixed into a SHA-256 over the remote address before the
# consent record persists. REQUIRED IN STAGING/PRODUCTION (the config
# validator refuses to boot with an empty or "dev-"-prefixed value); leave
# empty here in dev and the code falls back to a fixed dev-only salt.
IP_HASH_SALT=

# P0-4 (give-up affordance) — soft-block window before "Give up & reveal"
# becomes available on the workspace top bar. ADR 0010 locks the default at
# 600 seconds (10 minutes); override here for short missions or test envs.
# 0 = no gate; higher values gate longer (e.g. 1800 = 30 min for advanced
# missions). Per-mission overrides via mission.yaml are future work.
GIVE_UP_MIN_SECONDS=600

# P0-6 (account self-service) — number of days a generated data export's
# signed download URL stays valid before the row flips to ``expired``.
# Capped at 30 in code; shorter values are safer.
DATA_EXPORT_TTL_DAYS=7
# Number of days between POST /me/delete and the worker's hard-delete
# pass. The user can cancel at any time before then via the FE /account
# page. Capped at 30 in code.
ACCOUNT_DELETION_GRACE_DAYS=7
# Email domain stamped onto tombstone rows when the deletion worker
# hard-deletes an account. MUST be a domain you control AND cannot
# receive mail (so the tombstone identity cannot collide with a real
# sign-up). Staging / dev can override to keep tombstones from sharing
# identity across environments.
DELETED_TOMBSTONE_DOMAIN=deleted.openagentdojo.app

# Auth
SESSION_COOKIE_NAME=arena_session
# SESSION_SECRET signs the session cookie HMAC. The value below is a
# DEVELOPMENT-ONLY placeholder — the `dev-` prefix is what the staging/
# production config validator (apps/api/app/config.py) explicitly rejects,
# so accidentally shipping it to a real environment fails the boot loudly
# instead of silently signing real sessions with a public secret.
# REQUIRED IN PRODUCTION: replace with a random 64+ char string
# (`python -c "import secrets; print(secrets.token_urlsafe(64))"`).
SESSION_SECRET=dev-only-replace-before-deploy-aaaa
MAGIC_LINK_TTL_MINUTES=30
# Resend (preferred) — set RESEND_API_KEY in prod. Empty in local dev.
RESEND_API_KEY=
EMAIL_FROM=hello@arena.local
# Local SMTP fallback (Mailhog in compose). Used when RESEND_API_KEY is empty.
SMTP_HOST=localhost
SMTP_PORT=1025
# SMTP credentials and TLS verification for magic-link email
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_START_TLS=false
SMTP_VERIFY_CERTS=false
# ALLOW_DEV_AUTH=1 enables a non-email "log in as <email>" shortcut for E2E
# tests and local development. The config validator forbids this in
# staging/production — never set this in a deployed environment.
ALLOW_DEV_AUTH=
# SHARE_TOKEN_SECRET signs the opaque tokens behind /reports/{id}/share
# URLs. Must be set to a random 64+ char string in production; a separate
# secret keeps share-link forgery isolated from session-cookie forgery.
SHARE_TOKEN_SECRET=

# Features
FEATURE_LLM_NARRATION=false

# LLM (optional — see §16.A; full creds in keys.md)
# Leave ANTHROPIC_PROVIDER empty for direct Anthropic API; set to "bedrock" for AWS Bedrock.
# NOTE: do not put inline comments on the same line — Docker's .env parser keeps them as value.
ANTHROPIC_PROVIDER=
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-2
ANTHROPIC_API_KEY=

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=INFO

# Run provisioning in the API process (true) vs. via RQ workers (false, requires shared pool)
PROVISION_IN_PROCESS=true

# Mission content root (absolute path).
# Leave empty to default to <repo-root>/missions (auto-detected from this file's
# location). Inside the API container, compose sets this to /missions (the
# read-only bind mount).
MISSIONS_ROOT=

# --- Frontend (apps/web) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000
NEXT_PUBLIC_APP_ENV=development
# Public canonical URL of the deployed app (used by metadata/SEO in layout.tsx).
NEXT_PUBLIC_APP_URL=http://localhost:3000
# PostHog product analytics (optional). Both vars must be NEXT_PUBLIC_ to be readable in the FE bundle.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- CORS (backend) ---
# Origin allowed to call the API. Defaults to the local Next.js dev server.
WEB_ORIGIN=http://localhost:3000
# Extra CORS origins beyond WEB_ORIGIN (comma-separated)
CORS_EXTRA_ORIGINS=

# --- Trusted hosts (backend) ---
# Comma-separated Host header values the API accepts. "*" is permissive and
# only OK in local development; staging/production MUST set an explicit list
# (the config validator refuses to boot otherwise).
ALLOWED_HOSTS=*

# ─────────────────────────────────────────────────────────────────────
# BACKEND .env.example — settings consumed by apps/api only.
#
# WHAT THIS IS:
#   The subset of variables the FastAPI backend reads at boot. Mirrors
#   the backend-relevant rows of the root .env.example.
#
# WHEN TO USE IT:
#   • `cd apps/api && cp .env.example .env` — run the API standalone
#     (e.g. with `uv run uvicorn app.main:app`) without the compose stack.
#
# Frontend-only NEXT_PUBLIC_* vars are intentionally NOT included here;
# the Next.js dev server reads them from apps/web/.env.local (or the root
# .env.example via the compose stack).
# ─────────────────────────────────────────────────────────────────────

ARENA_ENV=development
DATABASE_URL=postgresql+asyncpg://arena:arena@localhost:5432/arena
SYNC_DATABASE_URL=postgresql://arena:arena@localhost:5432/arena
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=arena-minio
S3_SECRET_ACCESS_KEY=arena-minio-secret
S3_BUCKET=arena-artifacts
S3_REGION=us-east-1

# Sandbox driver
SANDBOX_DRIVER=local         # local | docker
SANDBOX_WORKDIR=/tmp/arena-sandboxes
SANDBOX_MAX_CONCURRENT=10
SANDBOX_TIMEOUT_SECONDS=1800
# Path to a docker seccomp JSON profile. Unset = built-in minimal profile.
ARENA_SECCOMP_PROFILE=
# Set ARENA_RUN_LOCAL_SETUP=1 to force mission setup_commands on the local
# driver (off by default — local driver is the fast/hermetic test path).
ARENA_RUN_LOCAL_SETUP=

# Auth
SESSION_COOKIE_NAME=arena_session
SESSION_SECRET=dev-secret-change-me-32-chars-min-aaaa
MAGIC_LINK_TTL_MINUTES=30
RESEND_API_KEY=
EMAIL_FROM=hello@arena.local
# Local SMTP fallback (Mailhog in compose). Used when RESEND_API_KEY is empty.
SMTP_HOST=localhost
SMTP_PORT=1025
# ALLOW_DEV_AUTH=1 enables a non-email "log in as <email>" shortcut for E2E
# tests and local development. Forbidden by the config validator in
# staging/production; leave empty in deployed environments.
ALLOW_DEV_AUTH=
# Signing secret for opaque /reports/{id}/share tokens. Random 64+ chars
# in production; rotate independently of SESSION_SECRET.
SHARE_TOKEN_SECRET=

# Features
FEATURE_LLM_NARRATION=false

# LLM (optional — see plan §16.A; real creds in keys.md)
ANTHROPIC_PROVIDER=
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-2
ANTHROPIC_API_KEY=

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=INFO

# Frontend origin allowed by CORS — the Next.js dev server in dev.
WEB_ORIGIN=http://localhost:3000

# Comma-separated Host header allowlist. "*" is permissive (dev only);
# staging/production MUST set an explicit list (config validator enforces).
ALLOWED_HOSTS=*

# Mission content root (absolute path).
# Leave empty to default to <repo-root>/missions (auto-detected from this file's location).
# Inside the API container, compose sets this to /missions (the read-only mount).
MISSIONS_ROOT=

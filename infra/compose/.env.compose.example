# ─────────────────────────────────────────────────────────────────────
# COMPOSE .env.example — values for the docker-compose stack.
#
# WHAT THIS IS:
#   The same shape as the root .env.example but with hostnames swapped
#   from `localhost` to compose service names (postgres, redis, minio).
#   The compose stack auto-loads `.env` from the repo root, so the
#   intended workflow is to copy THIS file there:
#
#     cp infra/compose/.env.compose.example .env   # from repo root
#
# WHEN TO USE IT:
#   • You ran `make up` / `pnpm compose:up` and want the right values
#     wired into every container in one shot.
#
# The root .env.example is the source of truth for variable NAMES;
# this file changes only HOSTS and a few container-only defaults.
# ─────────────────────────────────────────────────────────────────────

# --- Backend (apps/api) ---
ARENA_ENV=development
DATABASE_URL=postgresql+asyncpg://arena:arena@postgres:5432/arena
SYNC_DATABASE_URL=postgresql://arena:arena@postgres:5432/arena
REDIS_URL=redis://redis:6379/0

# --- Object storage (MinIO) ---
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=arena-minio
S3_SECRET_ACCESS_KEY=arena-minio-secret
S3_BUCKET=arena-artifacts
S3_REGION=us-east-1

# --- Sandbox driver ---
SANDBOX_DRIVER=docker
SANDBOX_WORKDIR=/tmp/arena-sandboxes
SANDBOX_MAX_CONCURRENT=10
SANDBOX_TIMEOUT_SECONDS=1800
# Path to a docker seccomp JSON profile applied to sandbox containers.
# Leave empty to use the built-in minimal profile.
ARENA_SECCOMP_PROFILE=
# Force mission setup on the local driver (=1). Not relevant when
# SANDBOX_DRIVER=docker, but documented here so the compose env mirrors
# the root contract.
ARENA_RUN_LOCAL_SETUP=

# --- Auth ---
SESSION_COOKIE_NAME=arena_session
SESSION_SECRET=dev-secret-change-me-32-chars-min-aaaa
MAGIC_LINK_TTL_MINUTES=30
RESEND_API_KEY=
EMAIL_FROM=hello@arena.local
# Mailhog ships in the compose stack on these ports.
SMTP_HOST=mailhog
SMTP_PORT=1025
# SMTP credentials and TLS verification for magic-link email
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_START_TLS=false
SMTP_VERIFY_CERTS=false
# Enable only for local development / E2E. Forbidden in staging/production.
ALLOW_DEV_AUTH=1
# Random secret in real deployments — empty here so a stray copy of this
# file to a real env fails loudly rather than silently signing tokens.
SHARE_TOKEN_SECRET=
# P0-11 — verification envelope HMAC. Same rules as SHARE_TOKEN_SECRET:
# empty here, ≥32 chars and distinct from the others in production.
VERIFY_SECRET=
REPORT_RENDER_FORCE_DAILY_CAP=5

# ── P0-7 — GitHub OAuth identity verification ──────────────────────────────
# When BOTH client id + secret are set, the FE's sign-in page surfaces a
# "Continue with GitHub" button alongside the magic-link form, and the
# public profile renders a verified-via-GitHub chip on every linked
# account. When EITHER is unset the OAuth surface is fully hidden — the
# FE's ``auth.isGithubOAuthAvailable()`` probe returns ``false`` and the
# backend's ``GET /auth/github/start`` returns 503 ``oauth_unavailable``
# as a defence-in-depth. Empty strings are treated as unset.
#
# Configure in GitHub at https://github.com/settings/applications/new with
# the Authorization callback URL set to
# ``${WEB_ORIGIN}/api/v1/auth/github/callback`` (or override via
# ``GITHUB_OAUTH_REDIRECT_URI`` below if API + web live on different hosts).
#
# NOTE on state-cookie signing: the ``state`` JWT that defends the OAuth
# callback against CSRF / replay is HS256-signed with ``SESSION_SECRET``
# and bounded by a 10-minute TTL. There is no separate ``OAUTH_STATE_SECRET``
# — re-using the session secret is intentional because the state cookie
# never outlives a single round-trip to github.com.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# Optional override for the OAuth redirect URI sent to github.com. Leave
# empty to derive from ``WEB_ORIGIN`` (the common deployment); set this
# only when API and web live on different hosts AND you want GitHub to
# call the API host directly.
GITHUB_OAUTH_REDIRECT_URI=

# --- P0-5 (legal pages + cookie consent) ---
# Bump CONSENT_POLICY_VERSION every time the cookie/privacy policy text
# changes so existing consent rows are treated as stale and the cookie
# banner re-prompts. Server stamps this into ``user_consents.version`` on
# every POST /me/consent.
CONSENT_POLICY_VERSION=1
# Mixed into a SHA-256 over the remote address before the consent record
# persists. REQUIRED IN STAGING/PRODUCTION (validator refuses to boot
# with an empty or "dev-"-prefixed value); empty in compose dev falls
# back to a fixed dev-only salt.
IP_HASH_SALT=

# --- P0-4 (give-up affordance) ---
# Soft-block window before "Give up & reveal" becomes available on the
# workspace top bar. ADR 0010 locks the default at 600s (10 min); 0 =
# no gate; higher values gate longer (e.g. 1800 = 30 min).
GIVE_UP_MIN_SECONDS=600

# --- P0-6 (account self-service) ---
# Days a generated data export's signed download URL stays valid before
# the row flips to ``expired``. Capped at 30 in code; shorter = safer.
DATA_EXPORT_TTL_DAYS=7
# Days between POST /me/delete and the worker's hard-delete pass. User
# can cancel at any time before then via the FE /account page. Capped
# at 30 in code.
ACCOUNT_DELETION_GRACE_DAYS=7
# Email domain stamped onto tombstone rows when the deletion worker
# hard-deletes an account. MUST be a domain you control AND cannot
# receive mail (so the tombstone identity cannot collide with a real
# sign-up). Staging / dev can override to keep tombstones from sharing
# identity across environments.
DELETED_TOMBSTONE_DOMAIN=deleted.openagentdojo.app

# --- Features ---
FEATURE_LLM_NARRATION=false

# --- LLM (optional — leave empty for fully local dev) ---
ANTHROPIC_PROVIDER=
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-2
ANTHROPIC_API_KEY=

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=INFO

# Run provisioning in the API process (true) vs. via RQ workers (false, requires shared pool)
PROVISION_IN_PROCESS=true

# --- Frontend (apps/web) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000
NEXT_PUBLIC_APP_ENV=development
# Public canonical URL of the deployed app (used by metadata/SEO in layout.tsx).
NEXT_PUBLIC_APP_URL=http://localhost:3000
# PostHog product analytics (optional). Both vars must be NEXT_PUBLIC_ to be readable in the FE bundle.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Build-time hint that lets the FE render the "Continue with GitHub" button
# without a network round-trip on first paint. Set to "true" only when the
# operator has also set GITHUB_OAUTH_CLIENT_ID + GITHUB_OAUTH_CLIENT_SECRET
# on the API. Complement, not replacement, for the runtime probe
# ``GET /auth/github/available`` — the runtime probe is the source of truth
# (the FE re-confirms before redirecting). Leaving this unset hides the
# button until the probe resolves, which is the safer default.
NEXT_PUBLIC_GITHUB_OAUTH_ENABLED=false

# --- CORS (backend) ---
WEB_ORIGIN=http://localhost:3000
# Extra CORS origins beyond WEB_ORIGIN (comma-separated)
CORS_EXTRA_ORIGINS=

# --- Trusted hosts (backend) ---
# Permissive "*" works for local compose. Staging/production deployments
# must set an explicit list (config validator enforces).
ALLOWED_HOSTS=*

# --- Mission content root ---
# Compose mounts the repo missions/ at /missions read-only.
MISSIONS_ROOT=/missions

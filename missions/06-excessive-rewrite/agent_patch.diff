--- /dev/null
+++ b/frontend/src/hooks/useDashboardData.ts
@@ -0,0 +1,67 @@
+import { useEffect, useReducer } from "react";
+
+export interface DashboardPayload {
+  ok: boolean;
+  userId: string;
+  widgets: string[];
+}
+
+export type DashboardState =
+  | { status: "loading" }
+  | { status: "loaded"; data: DashboardPayload }
+  | { status: "error"; error: string };
+
+type Action =
+  | { type: "loaded"; data: DashboardPayload }
+  | { type: "failed"; error: string };
+
+function reducer(state: DashboardState, action: Action): DashboardState {
+  switch (action.type) {
+    case "loaded":
+      return { status: "loaded", data: action.data };
+    case "failed":
+      // BUG (Mission 06): even after the rewrite, the error branch
+      // doesn't transition out of "loading" — the reducer returns
+      // the previous state, so the spinner sticks around.
+      return state;
+  }
+}
+
+const INITIAL: DashboardState = { status: "loading" };
+
+/**
+ * Fetch /dashboard on mount and expose the request lifecycle as a
+ * discriminated-union state machine.
+ */
+export function useDashboardData(): DashboardState {
+  const [state, dispatch] = useReducer(reducer, INITIAL);
+
+  useEffect(() => {
+    let cancelled = false;
+    async function load() {
+      try {
+        const res = await fetch("/dashboard", { credentials: "include" });
+        if (!res.ok) {
+          throw new Error(`request failed: ${res.status}`);
+        }
+        const body = (await res.json()) as DashboardPayload;
+        if (!cancelled) {
+          dispatch({ type: "loaded", data: body });
+        }
+      } catch (e) {
+        if (!cancelled) {
+          dispatch({
+            type: "failed",
+            error: e instanceof Error ? e.message : "failed",
+          });
+        }
+      }
+    }
+    load();
+    return () => {
+      cancelled = true;
+    };
+  }, []);
+
+  return state;
+}
